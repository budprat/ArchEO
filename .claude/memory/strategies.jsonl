{"id": "debug_systematic", "name": "Systematic Debugging", "description": "Methodical approach to finding and fixing bugs", "domain": "debugging", "task_types": ["debugging", "fix", "error"], "steps": ["1. Reproduce the error consistently", "2. Read the error message and stack trace carefully", "3. Form hypothesis about the cause", "4. Add logging/prints to verify hypothesis", "5. Fix the root cause, not just symptoms", "6. Verify the fix doesn't break other things", "7. Add a test to prevent regression"], "preconditions": ["error reported", "bug mentioned", "fix requested"], "success_rate": 0.7958662289180591, "uses_count": 0, "last_used": null}
{"id": "atom_of_thought", "name": "Atom of Thought", "description": "Decompose into independent atoms, validate each, synthesize", "domain": "reasoning", "task_types": ["evaluate", "compare", "analyze", "multi-part", "requirements"], "steps": ["1. Identify if problem is decomposable (not sequential)", "2. Break problem into independent atomic claims", "3. Verify each atom is self-contained (no 'this', 'therefore')", "4. Validate independence between atoms", "5. Verify correctness of each atom individually", "6. Assign confidence score to each validated atom", "7. Synthesize validated atoms into final answer", "8. Check synthesis consistency and completeness"], "preconditions": ["evaluate options", "compare alternatives", "assess tradeoffs", "weigh factors", "analyze requirements", "which approach", "pros and cons", "decision between"], "success_rate": 0.8798876802307964, "uses_count": 0, "last_used": null}
{"id": "explore_first", "name": "Exploration First", "description": "Understand before acting", "domain": "general", "task_types": ["unfamiliar", "complex", "new"], "steps": ["1. Survey the landscape (files, structure, patterns)", "2. Identify key components and their relationships", "3. Find similar examples or precedents", "4. Form a mental model", "5. Plan approach based on understanding", "6. Execute incrementally with verification", "7. Update mental model as needed"], "preconditions": ["unfamiliar", "new codebase", "first time", "complex"], "success_rate": 0.3225029553448094, "uses_count": 0, "last_used": null}
